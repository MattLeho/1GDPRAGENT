            "parameters": {
                "jsCode": "// Handle unknown file types\nconst data = items[0].json;\nreturn {\n  json: {\n    ...data,\n    extractedContent: null,\n    unknownType: true,\n    notes: 'Unknown file type - saved for manual review'\n  },\n  binary: items[0].binary\n};"
            },
