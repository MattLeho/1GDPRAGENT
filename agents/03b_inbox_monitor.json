        {
            "parameters": {
                "jsCode": "// Parse the AI classification and prepare database updates\nconst aiOutput = items[0].json.output || items[0].json.text || '';\nconst emailData = $('5. Match Emails to Requests').first().json;\nlet classification;\n\ntry {\n  const jsonMatch = aiOutput.match(/\\{[\\s\\S]*\\}/);\n  classification = jsonMatch ? JSON.parse(jsonMatch[0]) : { classification: 'UNRELATED', confidence: 0.5 };\n} catch (e) {\n  classification = {\n    classification: 'PROCESSING',\n    confidence: 0.3,\n    summary: 'Email received but parsing failed - manual review needed',\n    error: e.message\n  };\n}\n\n// Map classification to request status\nconst statusMap = {\n  'ACKNOWLEDGMENT': 'processing',\n  'VERIFICATION_NEEDED': 'action_required',\n  'PROCESSING': 'processing',\n  'DATA_READY': 'data_available',\n  'DATA_ATTACHED': 'data_received',\n  'PARTIAL_DATA': 'partial_data',\n  'REJECTION': 'rejected',\n  'EXTENSION': 'extended',\n  'CLARIFICATION': 'action_required',\n  'COMPLETION': 'completed',\n  'UNRELATED': null\n};\n\nconst newStatus = classification.statusUpdate || statusMap[classification.classification];\n\nreturn {\n  json: {\n    requestId: emailData.matchedRequestId,\n    company: emailData.matchedCompany,\n    emailId: emailData.emailId,\n    threadId: emailData.threadId,\n    emailFrom: emailData.from,\n    emailSubject: emailData.subject,\n    classification: classification,\n    newStatus: newStatus,\n    shouldUpdateStatus: newStatus !== null,\n    requiresUserAction: classification.nextAction?.required || false,\n    triggerDataIngestion: ['DATA_ATTACHED', 'DATA_READY'].includes(classification.classification),\n    processedAt: new Date().toISOString()\n  }\n};"
            },
