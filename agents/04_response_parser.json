            "parameters": {
                "jsCode": "// Parse AI analysis and store for this file\nconst aiOutput = items[0].json.output || items[0].json.text || '';\nconst inputData = items[0].json;\n\nlet analysis;\ntry {\n  const jsonMatch = aiOutput.match(/\\{[\\s\\S]*\\}/);\n  analysis = jsonMatch ? JSON.parse(jsonMatch[0]) : { error: 'Failed to parse', raw: aiOutput.substring(0, 500) };\n} catch (e) {\n  analysis = { error: e.message };\n}\n\nreturn {\n  json: {\n    ...inputData,\n    analysis: analysis,\n    analysisComplete: true\n  }\n};"
            },
