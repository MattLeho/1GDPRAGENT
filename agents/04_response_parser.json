            "parameters": {
                "jsCode": "// Get current file from queue\nconst inputData = $('2. Prepare Input & File Queue').first().json;\nconst currentIndex = items[0].json.currentFileIndex || 0;\nconst file = inputData.fileQueue[currentIndex];\n\nif (!file) {\n  return { json: { done: true, noMoreFiles: true } };\n}\n\nreturn {\n  json: {\n    ...items[0].json,\n    currentFile: file,\n    currentFileIndex: currentIndex,\n    totalFiles: inputData.totalFiles,\n    requestId: inputData.requestId,\n    companyName: inputData.companyName\n  }\n};"
            },
