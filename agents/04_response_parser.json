                "query": "INSERT INTO messages (request_id, sender, content, timestamp)\nVALUES (\n  '{{ $json.requestId }}'::uuid,\n  'agent',\n  '⚠️ ACTION REQUIRED: Company requires you to download files from their portal.\\n\\nPortal URL: {{ $json.portalUrl || \"Check your email\" }}\\n\\nPlease:\\n1. Log into the portal\\n2. Download your data export\\n3. Upload the files to this request\\n4. The parser will automatically process them',\n  NOW()\n)\nRETURNING id;",
                "options": {}
