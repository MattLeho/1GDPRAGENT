        {
            "parameters": {
                "jsCode": "// Detect file type from binary or filename\nconst binary = items[0].binary?.data;\nconst mimeType = binary?.mimeType || '';\nconst fileName = binary?.fileName || items[0].json.currentFile?.name || '';\nconst ext = fileName.split('.').pop()?.toLowerCase() || '';\n\n// Comprehensive file type mapping\nconst typeMapping = {\n  // Documents\n  'pdf': 'PDF',\n  'application/pdf': 'PDF',\n  \n  // Archives\n  'zip': 'ZIP',\n  'application/zip': 'ZIP',\n  'application/x-zip-compressed': 'ZIP',\n  \n  // Data files - JSON\n  'json': 'JSON',\n  'application/json': 'JSON',\n  \n  // Data files - CSV\n  'csv': 'CSV',\n  'text/csv': 'CSV',\n  'text/comma-separated-values': 'CSV',\n  \n  // Spreadsheets\n  'xls': 'SPREADSHEET',\n  'xlsx': 'SPREADSHEET',\n  'application/vnd.ms-excel': 'SPREADSHEET',\n  'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet': 'SPREADSHEET',\n  'ods': 'SPREADSHEET',\n  \n  // Images\n  'jpg': 'IMAGE',\n  'jpeg': 'IMAGE',\n  'png': 'IMAGE',\n  'gif': 'IMAGE',\n  'webp': 'IMAGE',\n  'bmp': 'IMAGE',\n  'image/jpeg': 'IMAGE',\n  'image/png': 'IMAGE',\n  'image/gif': 'IMAGE',\n  \n  // Video (CCTV, recordings)\n  'mp4': 'VIDEO',\n  'avi': 'VIDEO',\n  'mov': 'VIDEO',\n  'mkv': 'VIDEO',\n  'wmv': 'VIDEO',\n  'webm': 'VIDEO',\n  'video/mp4': 'VIDEO',\n  'video/x-msvideo': 'VIDEO',\n  'video/quicktime': 'VIDEO',\n  \n  // Audio (voice recordings)\n  'mp3': 'AUDIO',\n  'wav': 'AUDIO',\n  'ogg': 'AUDIO',\n  'm4a': 'AUDIO',\n  'flac': 'AUDIO',\n  'aac': 'AUDIO',\n  'audio/mpeg': 'AUDIO',\n  'audio/wav': 'AUDIO',\n  'audio/ogg': 'AUDIO',\n  \n  // Documents\n  'txt': 'TEXT',\n  'text/plain': 'TEXT',\n  'html': 'HTML',\n  'text/html': 'HTML',\n  'xml': 'XML',\n  'application/xml': 'XML'\n};\n\nlet fileType = typeMapping[ext] || typeMapping[mimeType] || 'UNKNOWN';\n\n// Calculate file size\nconst fileSize = binary?.fileSize || 0;\nconst fileSizeMB = (fileSize / (1024 * 1024)).toFixed(2);\n\nreturn {\n  json: {\n    ...items[0].json,\n    detectedType: fileType,\n    fileName: fileName,\n    mimeType: mimeType,\n    fileSizeMB: parseFloat(fileSizeMB),\n    requiresSpecialHandling: ['VIDEO', 'AUDIO', 'IMAGE'].includes(fileType),\n    canExtractText: ['PDF', 'JSON', 'CSV', 'TEXT', 'HTML', 'XML', 'SPREADSHEET'].includes(fileType)\n  },\n  binary: items[0].binary\n};"
            },
