# ═══════════════════════════════════════════════════════════════════════════
# GDPR Agent - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# Copy this to .env and fill in your values
# NEVER commit the actual .env file with real credentials!

# ─────────────────────────────────────────────────────────────────────────────
# PostgreSQL Database
# ─────────────────────────────────────────────────────────────────────────────
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=gdpr_local

# Constructed DATABASE_URL (uses Docker internal hostname 'postgres')
DATABASE_URL=postgresql://admin:change-me@postgres:5432/gdpr_local

# For local development (frontend running outside Docker)
DATABASE_URL_LOCAL=postgresql://admin:change-me@localhost:5432/gdpr_local

# ─────────────────────────────────────────────────────────────────────────────
# Redis (Task Queue)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me@redis:6379/0

# ─────────────────────────────────────────────────────────────────────────────
# Neo4j Knowledge Graph
# ─────────────────────────────────────────────────────────────────────────────
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-neo4j-password
NEO4J_URI=bolt://neo4j:7687
NEO4J_URI_LOCAL=bolt://localhost:7687

# ─────────────────────────────────────────────────────────────────────────────
# N8N Workflow Automation
# ─────────────────────────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=change-me-n8n-password
N8N_ENCRYPTION_KEY=change-me-random-32-byte-key
N8N_PUBLIC_URL=http://localhost:5678
N8N_INTERNAL_URL=http://n8n:5678

# N8N API Key (generate in N8N settings after first login)
N8N_API_KEY=your-n8n-api-key

# ─────────────────────────────────────────────────────────────────────────────
# Qdrant Vector Database (optional API key)
# ─────────────────────────────────────────────────────────────────────────────
QDRANT_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# AI API Keys
# ─────────────────────────────────────────────────────────────────────────────
# Google Gemini API Key (required)
GOOGLE_API_KEY=your-google-api-key
GEMINI_API_KEY=your-gemini-api-key

# OpenAI API Key (optional, for fallback)
OPENAI_API_KEY=your-openai-api-key

# AI Model Configuration
GEMINI_MODEL_PRO=gemini-3-pro-preview
GEMINI_MODEL_FLASH=gemini-3-flash-preview

# ─────────────────────────────────────────────────────────────────────────────
# Application URLs
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
INTELLIGENCE_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────────────────────
# Security Keys
# ─────────────────────────────────────────────────────────────────────────────
# Fernet key for credential encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_KEY=generate-with-python-cryptography-fernet

# ─────────────────────────────────────────────────────────────────────────────
# N8N Webhook URLs (configured after workflows are imported)
# ─────────────────────────────────────────────────────────────────────────────
N8N_WEBHOOK_ANALYZE_POLICY=http://localhost:5678/webhook/analyze-policy
N8N_WEBHOOK_DRAFT_REQUEST=http://localhost:5678/webhook/draft-request
N8N_WEBHOOK_SEND_EMAIL=http://localhost:5678/webhook/send-email
N8N_WEBHOOK_TEST_IMAP=http://localhost:5678/webhook/test-imap
N8N_WEBHOOK_INGEST_DATA=http://localhost:5678/webhook/ingest-data
N8N_WEBHOOK_INGEST_IDENTITY=http://localhost:5678/webhook/ingest-identity
N8N_WEBHOOK_FILE_TRANSCRIPTION=http://localhost:5678/webhook/file-transcription
N8N_WEBHOOK_VENDOR_EXTRACT=http://localhost:5678/webhook/vendor-extract
N8N_WEBHOOK_POLICY_SCAN=http://localhost:5678/webhook/policy-scan
N8N_WEBHOOK_ENHANCED_RAG=http://localhost:5678/webhook/enhanced-rag




