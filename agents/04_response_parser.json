                }
            }
        },
        {
            "parameters": {
                "jsCode": "// Compile all analyses into final response\nconst inputData = $('2. Prepare Input & File Queue').first().json;\nconst allAnalyses = $('17. Log File Processed').all().map(item => item.json.analysis).filter(a => a);\n\n// Calculate aggregate stats\nlet totalDataPoints = 0;\nlet maxRiskScore = 0;\nconst allCategories = {};\nconst allThirdParties = new Set();\nconst allRecommendations = new Set();\n\nfor (const analysis of allAnalyses) {\n  if (analysis.dataPointsFound) totalDataPoints += analysis.dataPointsFound;\n  if (analysis.riskScore) maxRiskScore = Math.max(maxRiskScore, analysis.riskScore);\n  if (analysis.thirdPartiesDetected) {\n    analysis.thirdPartiesDetected.forEach(tp => allThirdParties.add(tp));\n  }\n  if (analysis.recommendedActions) {\n    analysis.recommendedActions.forEach(r => allRecommendations.add(r));\n  }\n  if (analysis.categories) {\n    for (const [cat, data] of Object.entries(analysis.categories)) {\n      if (!allCategories[cat]) allCategories[cat] = { count: 0, examples: [] };\n      allCategories[cat].count += data.count || 0;\n      allCategories[cat].examples.push(...(data.examples || []).slice(0, 2));\n    }\n  }\n}\n\nreturn {\n  json: {\n    success: true,\n    requestId: inputData.requestId,\n    companyName: inputData.companyName,\n    filesProcessed: allAnalyses.length,\n    aggregateAnalysis: {\n      totalDataPoints: totalDataPoints,\n      overallRiskScore: maxRiskScore,\n      categoriesSummary: allCategories,\n      thirdPartiesDetected: Array.from(allThirdParties),\n      recommendedActions: Array.from(allRecommendations)\n    },\n    processedAt: new Date().toISOString()\n  }\n};"
            },
