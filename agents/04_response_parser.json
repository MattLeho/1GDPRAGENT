            "name": "1. Webhook: Parse Response",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 2,
            "position": [
                100,
                300
            ],
            "webhookId": "parse-response-webhook"
        },
        {
            "parameters": {
                "jsCode": "// Extract request data and check for user uploads\nconst input = items[0].json.body || items[0].json;\n\n// Check if user uploaded files directly or if we have download links\nconst hasDownloadLinks = (input.downloadLinks || []).length > 0;\nconst hasUploadedFiles = (input.uploadedFiles || []).length > 0;\nconst requiresManualDownload = input.requiresManualDownload || false;\nconst portalUrl = input.portalUrl || null;\n\n// Build file queue\nlet fileQueue = [];\n\nif (hasDownloadLinks) {\n  for (const url of input.downloadLinks) {\n    fileQueue.push({ type: 'download', url: url, source: 'company_link' });\n  }\n}\n\nif (hasUploadedFiles) {\n  for (const file of input.uploadedFiles) {\n    fileQueue.push({ type: 'uploaded', path: file.path, name: file.name, source: 'user_upload' });\n  }\n}\n\nreturn {\n  json: {\n    requestId: input.requestId,\n    companyName: input.companyName || 'Unknown Company',\n    fileQueue: fileQueue,\n    totalFiles: fileQueue.length,\n    currentFileIndex: 0,\n    requiresManualDownload: requiresManualDownload,\n    portalUrl: portalUrl,\n    source: input.source || 'manual',\n    processedFiles: [],\n    allAnalyses: [],\n    startedAt: new Date().toISOString()\n  }\n};"
            },
            "id": "prepare-input",
            "name": "2. Prepare Input & File Queue",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                320,
                300
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "requires-manual",
                            "leftValue": "={{ $json.requiresManualDownload }}",
                            "rightValue": true,
                            "operator": {
                                "type": "boolean",
                                "operation": "equals"
                            }
                        }
                    ],
                    "combinator": "and"
                },
                "options": {}
            },
            "id": "if-manual-download",
