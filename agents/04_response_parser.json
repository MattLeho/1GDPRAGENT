        {
            "parameters": {
                "jsCode": "// For media files, we can't extract content but log metadata\nconst data = items[0].json;\nconst binary = items[0].binary?.data;\n\nreturn {\n  json: {\n    ...data,\n    extractedContent: null,\n    mediaMetadata: {\n      type: data.detectedType,\n      fileName: data.fileName,\n      sizeMB: data.fileSizeMB,\n      mimeType: data.mimeType,\n      notes: 'Media file saved for manual review. May contain CCTV footage, voice recordings, or images.'\n    },\n    needsManualReview: true\n  },\n  binary: items[0].binary\n};"
            },
            "id": "handle-media",
            "name": "12f. Handle Media File",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
