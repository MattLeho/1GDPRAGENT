        {
            "parameters": {
                "mode": "combine",
                "mergeByFields": {
                    "values": []
                }
            },
            "id": "merge-verdicts",
            "name": "4. Merge Agent Verdicts",
            "type": "n8n-nodes-base.merge",
            "typeVersion": 3,
            "position": [
                1050,
                450
            ]
        },
        {
            "parameters": {
                "jsCode": "// Parse all 4 agent outputs and count votes\nconst hf = $('3a. Head Forward Agent').first()?.json?.output || '';\nconst hb = $('3b. Head Backward Agent').first()?.json?.output || '';\nconst tf = $('3c. Tail Forward Agent').first()?.json?.output || '';\nconst tb = $('3d. Tail Backward Agent').first()?.json?.output || '';\nconst input = $('2. Prepare Input').first().json;\n\nfunction parse(out) {\n  try {\n    const m = out.match(/\\{[\\s\\S]*\\}/);\n    return m ? JSON.parse(m[0]) : { verdict: 'UNKNOWN', confidence: 5 };\n  } catch { return { verdict: 'UNKNOWN', confidence: 5 }; }\n}\n\nconst agents = {\n  headForward: parse(hf),\n  headBackward: parse(hb),\n  tailForward: parse(tf),\n  tailBackward: parse(tb)\n};\n\nlet correct = 0, incorrect = 0;\nfor (const v of Object.values(agents)) {\n  if (v.verdict?.toUpperCase() === 'CORRECT') correct++;\n  else if (v.verdict?.toUpperCase() === 'INCORRECT') incorrect++;\n}\n\nconst consensus = correct === 4 || incorrect === 4;\nconst majority = correct >= 3 || incorrect >= 3;\nconst tie = correct === 2 && incorrect === 2;\nconst shouldContinue = !consensus && !majority && input.discussionRound < input.maxRounds;\n\nreturn {\n  json: {\n    ...input,\n    agentResponses: agents,\n    votes: { correct, incorrect },\n    consensus,\n    majority,\n    tie,\n    shouldContinue,\n    decision: consensus || majority ? (correct > incorrect ? 'ACCEPT' : 'REJECT') : (tie ? 'TIE' : 'CONTINUE')\n  }\n};"
            },
            "id": "count-votes",
            "name": "5. Count Votes",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1270,
                450
            ]
        },
        {
            "parameters": {
                "conditions": {
                    "boolean": [
                        {
                            "value1": "={{ $json.shouldContinue }}",
                            "value2": true
                        }
                    ]
                }
            },
            "id": "check-continue",
            "name": "6. Continue Discussion?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2.2,
            "position": [
                1490,
                450
            ]
        },
        {
            "parameters": {
                "jsCode": "// Increment round and prepare for next iteration\nconst data = $input.first().json;\nreturn {\n  json: {\n    triple: data.triple,\n    sourceText: data.sourceText,\n    requestId: data.requestId,\n    discussionRound: data.discussionRound + 1,\n    maxRounds: data.maxRounds,\n    agentResponses: data.agentResponses\n  }\n};"
            },
            "id": "increment-round",
            "name": "7a. Increment Round",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1710,
                350
            ],
            "notes": "ITERATION: Prepares next discussion round with previous responses for agents to consider"
        },
        {
            "parameters": {
                "jsCode": "// Format final decision\nconst data = $input.first().json;\n\nlet cypherStatement = null;\nif (data.decision === 'ACCEPT' || (data.tie && data.votes.correct >= 2)) {\n  const rel = data.triple.relation.toUpperCase().replace(/[^A-Z_]/g, '_');\n  cypherStatement = `MERGE (h {value: '${data.triple.head}'}) MERGE (t {value: '${data.triple.tail}'}) MERGE (h)-[:${rel}]->(t)`;\n}\n\nreturn {\n  json: {\n    success: true,\n    triple: data.triple,\n    decision: data.decision === 'TIE' ? 'NEEDS_REVIEW' : data.decision,\n    votes: data.votes,\n    rounds: data.discussionRound,\n    cypherStatement,\n    agentResponses: data.agentResponses\n  }\n};"
            },
            "id": "format-decision",
            "name": "7b. Format Final Decision",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                1710,
                550
            ]
        },
        {
            "parameters": {
                "method": "POST",
                "url": "http://n8n:5678/webhook/neo4j-query",
                "sendBody": true,
                "specifyBody": "json",
                "jsonBody": "={\"query\": \"{{ $json.cypherStatement }}\", \"mode\": \"write\"}"
            },
            "id": "apply-to-graph",
            "name": "8. Apply to Graph (if ACCEPT)",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1930,
                450
            ],
            "continueOnFail": true,
            "notes": "Uses workflow 09 to write accepted triple"
        },
        {
            "parameters": {
                "respondWith": "json",
                "responseBody": "={{ $json }}"
            },
            "id": "respond",
            "name": "9. Respond",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1.1,
            "position": [
                2150,
                450
            ]
        }
    ],
