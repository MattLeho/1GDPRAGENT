        {
            "parameters": {
                "jsCode": "// Get the list of active company domains from requests\nconst activeRequests = $('2. Get Active Requests').all();\nconst emails = $input.all();\n\nif (!emails || emails.length === 0) {\n  return [{ json: { noEmails: true } }];\n}\n\nconst matchedEmails = [];\n\nfor (const email of emails) {\n  const fromEmail = email.json.from || '';\n  const fromDomain = fromEmail.split('@')[1]?.split('>')[0] || '';\n  \n  // Check if email is from any of our active request companies\n  for (const req of activeRequests) {\n    const companyDomain = (req.json.company_url || req.json.company_name || '')\n      .toLowerCase()\n      .replace(/^https?:\\/\\//, '')\n      .replace('www.', '')\n      .split('/')[0]\n      .split('.')[0];\n    \n    const isMatch = fromDomain.toLowerCase().includes(companyDomain) ||\n                    companyDomain.includes(fromDomain.split('.')[0]);\n    \n    if (isMatch && companyDomain.length > 2) {\n      matchedEmails.push({\n        json: {\n          emailId: email.json.id,\n          threadId: email.json.threadId,\n          from: fromEmail,\n          subject: email.json.subject,\n          snippet: email.json.snippet,\n          date: email.json.date,\n          hasAttachments: (email.json.payload?.parts || []).some(p => p.filename),\n          matchedRequestId: req.json.id,\n          matchedCompany: req.json.company_name,\n          daysSinceSent: req.json.days_since_sent,\n          requestType: req.json.request_type\n        }\n      });\n      break;\n    }\n  }\n}\n\nreturn matchedEmails.length > 0 ? matchedEmails : [{ json: { noMatches: true } }];"
            },
