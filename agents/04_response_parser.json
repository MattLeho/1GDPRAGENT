                "query": "INSERT INTO messages (request_id, sender, content, timestamp)\nVALUES (\n  '{{ $json.requestId }}'::uuid,\n  'agent',\n  '📁 Processed file: {{ $json.fileName }}\\nType: {{ $json.detectedType }}\\nRisk Score: {{ $json.analysis.riskScore || \"Unknown\" }}\\nData Points: {{ $json.analysis.dataPointsFound || \"Unknown\" }}\\n\\n{{ ($json.analysis.summary || \"Analysis complete\").substring(0, 300) }}',\n  NOW()\n)\nRETURNING id;",
                "options": {}
            },
